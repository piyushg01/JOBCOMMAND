{
  "name": "messages",
  "primary_key_column": "id",
  "enable_rls": true,
  "visibility": "POD",
  "columns": [
    {
      "name": "application_id",
      "type": "UUID",
      "required": true,
      "foreign_key": {
        "references": "applications.id"
      }
    },
    {
      "name": "message_type",
      "type": "ENUM",
      "required": true,
      "options": [
        "outreach",
        "follow_up",
        "thank_you",
        "recruiter_reply",
        "custom"
      ]
    },
    {
      "name": "subject",
      "type": "TEXT",
      "max_length": 250
    },
    {
      "name": "content",
      "type": "TEXT",
      "required": true
    },
    {
      "name": "status",
      "type": "ENUM",
      "required": true,
      "default": "draft",
      "options": [
        "draft",
        "approved",
        "edited",
        "sent",
        "archived"
      ]
    },
    {
      "name": "channel",
      "type": "ENUM",
      "required": true,
      "default": "email",
      "options": [
        "email",
        "linkedin",
        "company_portal",
        "other"
      ]
    },
    {
      "name": "tone",
      "type": "ENUM",
      "required": true,
      "default": "professional",
      "options": [
        "professional",
        "friendly",
        "confident",
        "formal"
      ]
    },
    {
      "name": "ai_generated",
      "type": "BOOLEAN",
      "default": true
    },
    {
      "name": "human_edited",
      "type": "BOOLEAN",
      "default": false
    },
    {
      "name": "version",
      "type": "INTEGER",
      "default": 1
    },
    {
      "name": "approved_at",
      "type": "DATETIME"
    },
    {
      "name": "sent_at",
      "type": "DATETIME"
    },
    {
      "name": "notes",
      "type": "TEXT"
    }
  ],
  "config": {}
}
